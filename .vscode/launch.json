{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // 调试 01_chatmodel 例子
            "name": "Debug 01_chatmodel",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/examples/01_chatmodel",
            // cwd 固定在项目根目录，保证 godotenv.Load() 能找到 ./.env
            "cwd": "${workspaceFolder}",
            // 调试器直接把 .env 注入环境，断点里也能拿到 key/url/model
            "envFile": "${workspaceFolder}/.env"
        },
        {
            // 调试当前打开文件所在的 package（通用，换例子不用改配置）
            "name": "Debug current package",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
