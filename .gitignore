# 本地环境变量，含密钥，禁止提交
.env

# iOS 本地密钥（照 Secrets.swift.example 抄一份），禁止提交
ios/MenuAgent/MenuAgent/Secrets.swift

# 自签证书（scripts/gen-certs.sh 生成）。ca.key 是根私钥，泄露=可冒充服务器，绝不入库
certs/

# Go
/bin/

# 运行时数据（家庭库存账本等），agent 会写它，不入库
/data/

# iOS / Xcode 构建产物与用户私有状态
ios/**/build/
ios/**/DerivedData/
ios/**/xcuserdata/
ios/**/*.xcuserstate

# macOS
.DS_Store
